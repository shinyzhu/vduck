{
	"name": "hidestina",
	"version": "1.1.0",
	"description": "A modern chat UI for custom LLMs and MCP tools",
	"main": "src/server.js",
	"scripts": {
		"start": "node src/server.js",
		"dev": "node --watch src/server.js",
		"build:css": "tailwindcss --input src/css/input.css --output public/js/tailwind.css --content public/index.html --minify",
		"build": "npm run build:css"
	},
	"keywords": [
		"chat",
		"llm",
		"mcp",
		"express"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.2",
		"openai": "^6.39.1",
		"uuid": "^14.0.0"
	},
	"devDependencies": {
		"@highlightjs/cdn-assets": "^11.11.1",
		"@tailwindcss/cli": "^4.3.0",
		"highlight.js": "^11.11.1",
		"marked": "^18.0.4",
		"tailwindcss": "^4.3.0"
	}
}