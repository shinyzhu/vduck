# vduck Environment Variables

# Server port (default: 3000)
PORT=3000

# Optional: Default OpenAI-compatible API key (used when no provider is selected)
OPENAI_API_KEY=your-api-key-here

# Optional: Default LLM base URL (e.g. Ollama: http://localhost:11434/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Default model name (used when no model is selected)
MODEL_NAME=
